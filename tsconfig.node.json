{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "nodejs/services",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/services/**/*.ts"],
  "exclude": ["src/services/**/*.test.ts", "src/services/**/*.test.tsx"]
}

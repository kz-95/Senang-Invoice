# MyInvois portal base URL — used to build the public QR validation link
# ({base}/{uuid}/share/{longId}). Safe to expose.
NEXT_PUBLIC_MYINVOIS_BASE=https://preprod.myinvois.hasil.gov.my

# MyInvois e-invoice API — SERVER-SIDE ONLY (sandbox/preprod).
# MODE=mock  -> validationService fakes uuid/longId/QR (no network, default).
# MODE=sandbox -> real OAuth + DocumentSubmission against preprod-api (unsigned JSON).
# MODE=production -> real OAuth + XAdES-signed XML submission against production API.
# Client ID/Secret come from MyInvois portal > Profile > View and Register ERP.
# Client Secret is resolved SERVER-SIDE ONLY — never sent from the client.
SENANG_MYINVOIS_MODE=mock
SENANG_MYINVOIS_CLIENT_ID=
SENANG_MYINVOIS_CLIENT_SECRET=
SENANG_MYINVOIS_API_BASE=https://preprod-api.myinvois.hasil.gov.my

# MyInvois Digital Certificate (production only)
# SENANG_MYINVOIS_SIGNING_MODE=sandbox   # sandbox|production
# SENANG_MYINVOIS_CERT_PATH=/etc/certs/myinvois-cert.pem
# SENANG_MYINVOIS_KEY_PATH=/etc/certs/myinvois-key.pem
# SENANG_MYINVOIS_CERT_PASSPHRASE=       # optional, for encrypted keys

# Google Drive Sync — Client IDs from Google Cloud Console
# Web application OAuth client ID (for desktop PWA)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Web application OAuth client ID (same value set in android/.../strings.xml as server_client_id)
NEXT_PUBLIC_GOOGLE_NATIVE_CLIENT_ID=

# LLM keys — SERVER-SIDE ONLY (comma-separated, format: provider:apiKey)
# Do NOT prefix with NEXT_PUBLIC_ : that would inline the keys into the public
# browser bundle. These stay on the server; the app seeds them into Settings at
# runtime via the server-gated /api/seed-keys route (see SENANG_ALLOW_KEY_SEED).
SENANG_LLM_KEYS=gemini:AIza...,gemini:AIza...,deepseek:sk-...
SENANG_LLM_MODEL=gemini-2.5-flash-lite
SENANG_LLM_FALLBACK=deepseek-v4-flash

# Allow /api/seed-keys to serve keys to the local client in PRODUCTION mode.
# Leave unset on any shared/public deploy. Auto-allowed in dev (next dev).
# Set to true only for a local single-user production run (e.g. local APK).
SENANG_ALLOW_KEY_SEED=true

# Contact form — the /api/contact backend route POSTs submissions here.
# SERVER-SIDE ONLY. Create a form at formspree.io and paste its endpoint.
SENANG_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Public contact email shown on the About page. Single value, not translated.
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com

# Download links for the marketing landing page
# NEXT_PUBLIC_APK_URL=/senang-invoice.apk   # standalone APK download URL
# NEXT_PUBLIC_PLAYSTORE_URL=                 # Google Play Store listing URL
